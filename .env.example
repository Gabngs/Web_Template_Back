APP_NAME="Web Template"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =========================================
# BASE DE DATOS
# =========================================
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=web_template_db
DB_USERNAME=sail
DB_PASSWORD=123456

FORWARD_DB_PORT=3322
APP_PORT=8889
VITE_PORT=5174

# =========================================
# SWAGGER
# =========================================
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8889

# Swagger Documentation Auth (solo en producción - APP_ENV != local)
SWAGGER_USER=docs
SWAGGER_PASSWORD=

# =========================================
# KEYCLOAK - Identity Provider
# Panel admin: http://localhost:KC_PORT/admin  (KC_ADMIN_USER / KC_ADMIN_PASSWORD)
# Cambiar KC_CLIENT_SECRET en producción
# =========================================
KC_URL=http://keycloak:8080
KC_REALM=web-template
KC_CLIENT_ID=web-backend
KC_CLIENT_SECRET=change-me-in-production
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin_dev
KC_DB_PASSWORD=keycloak_pass
KC_PORT=8080
KC_JWKS_CACHE_TTL=300

# =========================================
# SESIONES Y CACHÉ
# DESARROLLO: database (sin dependencias extra)
# PRODUCCIÓN: redis (más rápido)
# =========================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# DESARROLLO: sync | PRODUCCIÓN: database o redis
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

# =========================================
# REDIS (opcional - para producción)
# =========================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =========================================
# EMAILS
# DESARROLLO: log (no envía nada, solo registra)
# PRODUCCIÓN: smtp con Gmail o Mailgun (descomentar)
# =========================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- PRODUCCIÓN: Gmail ---
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu-correo@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx  # App Password de Google (16 chars)
# MAIL_ENCRYPTION=tls

# --- PRODUCCIÓN: Mailgun (recomendado) ---
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=mg.tudominio.com
# MAILGUN_SECRET=key-xxxxxxxxxx

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
WWWUSER=1000
WWWGROUP=1000
